---
// Hero — "Argus × Hermes": Michelangelo's Creation of Adam (public domain),
// duotone (Adam=amber/cash, God=green/compute), with a spark + live ledger
// born at the fingertips. Honours prefers-reduced-motion.
---
<section id="hero" class="adam-hero">
  <img class="adam-img" src="/creation-of-adam.webp" alt="Detail of Michelangelo's Creation of Adam: two hands reaching toward each other." />
  <div class="tint amber" aria-hidden="true"></div>
  <div class="tint green" aria-hidden="true"></div>
  <div class="vignette" aria-hidden="true"></div>
  <canvas id="fx" aria-hidden="true"></canvas>

  <div class="content">
    <div class="top">
      <span class="eyebrow">Argus — Nous × NVIDIA × Stripe Hackathon 2026</span>
      <h1 style="margin-top: 20px; max-width: 18ch;">
        Where <span class="cash">Argus</span> meets <span class="gpu">Hermes</span>,
        capital becomes margin.
      </h1>
    </div>

    <div class="bottom">
      <div class="labels">
        <span class="cash mono">ARGUS · governance</span>
        <span class="gpu mono">HERMES · fleet</span>
      </div>
      <div class="ledger-live"><span class="livedot"></span> Live ledger · born at the touch</div>
      <div class="hero-grid">
        <div class="hero-tile">
          <span class="eyebrow cash">Cash</span>
          <p class="mono tile-num" id="cashNum">$ 200.00</p>
          <div class="bar"><span class="bar-fill" id="cashBar" style="width: 100%; background: var(--accent);"></span></div>
        </div>
        <div class="hero-tile">
          <span class="eyebrow gpu">Compute</span>
          <p class="mono tile-num" id="computeNum">$ 15.32</p>
          <div class="bar"><span class="bar-fill" id="computeBar" style="width: 100%; background: var(--accent-2);"></span></div>
        </div>
        <div class="hero-tile">
          <span class="eyebrow">Margin</span>
          <p class="mono tile-num" id="marginNum" style="color: var(--accent-2);">+ $ 184.68</p>
          <div class="bar"><span class="bar-fill" id="marginBar" style="width: 92%; background: var(--accent-2);"></span></div>
        </div>
      </div>
      <p class="audit mono" id="audit"><span class="badge" style="background:#76e89a">MARGIN</span>+$184.68 net · live</p>
    </div>
  </div>
</section>

<style>
  .adam-hero {
    position: relative; min-height: 100vh; overflow: hidden; isolation: isolate;
    display: flex; border-bottom: none;
  }
  .adam-img {
    position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0;
    object-fit: cover; object-position: 50% 45.6%;
    filter: grayscale(1) contrast(1.2) brightness(0.5);
  }
  .tint { position: absolute; inset: 0; pointer-events: none; z-index: 1; mix-blend-mode: color; }
  .tint.amber { background: linear-gradient(90deg, rgba(255,203,71,0.95) 0%, rgba(255,203,71,0.55) 28%, transparent 52%); }
  .tint.green { background: linear-gradient(270deg, rgba(118,232,154,0.95) 0%, rgba(118,232,154,0.55) 28%, transparent 52%); }
  .vignette {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background:
      radial-gradient(80% 70% at 50% 46%, transparent 0%, transparent 40%, rgba(8,9,11,0.72) 100%),
      linear-gradient(180deg, rgba(8,9,11,0.55) 0%, transparent 24%, transparent 52%, rgba(8,9,11,0.97) 92%);
  }
  #fx { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 3; pointer-events: none; }

  .content {
    position: relative; z-index: 4; width: 100%;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 64px 24px 56px; pointer-events: none;
  }
  .top, .bottom { max-width: 1120px; margin: 0 auto; width: 100%; }
  .top { text-align: center; }
  h1 { margin-inline: auto; }
  .content .hero-tile { pointer-events: auto; }

  .bottom { text-align: center; }
  .labels {
    display: flex; align-items: center; justify-content: space-between;
    max-width: 620px; margin: 0 auto 28px; font-size: 12px; letter-spacing: 0.16em;
  }
  .ledger-live {
    display: flex; align-items: center; gap: 9px; justify-content: center;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--fg-dim);
  }
  .livedot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-2); animation: livepulse 1.7s infinite; }
  @keyframes livepulse {
    0% { box-shadow: 0 0 0 0 rgba(118,232,154,0.55); }
    70% { box-shadow: 0 0 0 9px rgba(118,232,154,0); }
    100% { box-shadow: 0 0 0 0 rgba(118,232,154,0); }
  }
  .hero-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; max-width: 620px; margin: 14px auto 0; }
  .hero-tile {
    padding: 18px; border: 1px solid var(--line); border-radius: var(--radius);
    background: rgba(15,17,21,0.6); backdrop-filter: blur(8px); text-align: left;
  }
  .tile-num { margin-top: 10px; color: var(--fg); font-size: 24px; }
  .bar { margin-top: 12px; height: 4px; border-radius: 999px; background: rgba(255,255,255,0.08); overflow: hidden; }
  .bar-fill { display: block; height: 100%; border-radius: 999px; transition: width 0.18s linear; }
  .audit { margin-top: 16px; min-height: 1.5em; font-size: 12px; color: var(--fg-dim); transition: opacity 0.25s; }
  .audit .badge { color: var(--bg); padding: 2px 7px; border-radius: 5px; font-size: 10px; letter-spacing: 0.08em; margin-right: 9px; }

  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; max-width: 320px; }
    .labels { max-width: 320px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .livedot { animation: none; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Fingertips sit at the centre of the (re-cropped) fresco.
  const IMG_FOCAL = { ix: 0.5, iy: 0.456 };
  const OBJ_POS = { x: 0.5, y: 0.456 }; // must match .adam-img object-position
  const adamImg = document.querySelector('.adam-img') as HTMLImageElement;
  const canvas = document.getElementById('fx') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let dpr = 1;
  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(window.innerWidth * dpr);
    canvas.height = Math.floor(window.innerHeight * dpr);
  }
  resize();

  let pulse = 0;
  function focal() {
    const cw = window.innerWidth, ch = window.innerHeight;
    const iw = adamImg.naturalWidth || 2643, ih = adamImg.naturalHeight || 1599;
    const scale = Math.max(cw / iw, ch / ih);
    const dispW = iw * scale, dispH = ih * scale;
    const offX = (cw - dispW) * OBJ_POS.x, offY = (ch - dispH) * OBJ_POS.y;
    return { x: offX + IMG_FOCAL.ix * dispW, y: offY + IMG_FOCAL.iy * dispH };
  }

  function drawSpark(F: { x: number; y: number }, R: number) {
    const g = ctx.createRadialGradient(F.x, F.y, 0, F.x, F.y, R);
    g.addColorStop(0, 'rgba(255,255,255,0.95)');
    g.addColorStop(0.3, `rgba(255,240,200,${0.6 + pulse * 0.3})`);
    g.addColorStop(0.7, `rgba(150,220,160,${0.22 + pulse * 0.2})`);
    g.addColorStop(1, 'rgba(118,232,154,0)');
    ctx.beginPath(); ctx.arc(F.x, F.y, R, 0, Math.PI * 2);
    ctx.fillStyle = g; ctx.fill();
  }

  if (reduce) {
    // static: just the spark, no particles, no rAF
    const paint = () => {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      drawSpark(focal(), 30);
    };
    paint();
    window.addEventListener('resize', () => { resize(); paint(); });
  } else {
    window.addEventListener('resize', resize);

    type P = { side: number; ox: number; oy: number; t: number; sp: number; sz: number };
    const parts: P[] = [];
    function origin(side: number) {
      const W = window.innerWidth, H = window.innerHeight, F = focal();
      return side < 0
        ? { x: W * 0.10 + Math.random() * W * 0.16, y: F.y + (Math.random() - 0.3) * H * 0.22 }
        : { x: W * 0.74 + Math.random() * W * 0.16, y: F.y + (Math.random() - 0.7) * H * 0.22 };
    }
    for (let i = 0; i < 80; i++) {
      const side = i % 2 === 0 ? -1 : 1;
      const o = origin(side);
      parts.push({ side, ox: o.x, oy: o.y, t: Math.random(), sp: 0.0025 + Math.random() * 0.004, sz: 1 + Math.random() * 2 });
    }

    function frame() {
      const W = window.innerWidth, H = window.innerHeight, F = focal();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = 'lighter';
      for (const p of parts) {
        p.t += p.sp;
        if (p.t >= 1) { const o = origin(p.side); p.ox = o.x; p.oy = o.y; p.t = 0; }
        const e = p.t * p.t;
        const x = p.ox + (F.x - p.ox) * e, y = p.oy + (F.y - p.oy) * e;
        const col = p.side < 0 ? '255,203,71' : '118,232,154';
        ctx.beginPath();
        ctx.arc(x, y, p.sz * (0.6 + p.t), 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${col},${0.15 + p.t * 0.7})`;
        ctx.fill();
      }
      drawSpark(F, 22 + pulse * 48 + Math.sin(Date.now() / 320) * 4);
      ctx.globalCompositeOperation = 'source-over';
      pulse *= 0.93;
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  // ── Live ledger ───────────────────────────────────────────────────────
  const $ = (id: string) => document.getElementById(id)!;
  const cashNum = $('cashNum'), computeNum = $('computeNum'), marginNum = $('marginNum');
  const cashBar = $('cashBar') as HTMLElement, computeBar = $('computeBar') as HTMLElement, marginBar = $('marginBar') as HTMLElement;
  const auditEl = $('audit');
  const CASH = 200, PROJECTED = 15.32, CYCLE = 9000;
  const fmt = (n: number) => '$ ' + n.toFixed(2);

  if (!reduce) {
    const events = [
      { at: 0.06, badge: 'REVENUE', bg: '#ffcb47', text: '+$200.00 · Job A commission' },
      { at: 0.20, badge: 'TIER', bg: '#76e89a', text: 'compute_tier_assigned · Nemotron 3 Ultra' },
      { at: 0.62, badge: 'BURN', bg: '#9aa3ad', text: 'burn 70% of projection · margin watch' },
      { at: 0.92, badge: 'MARGIN', bg: '#76e89a', text: '+$184.68 net · live' },
    ];
    let lastCyc = 1;
    const fired = new Set<number>();
    function showAudit(e: typeof events[number]) {
      auditEl.style.opacity = '0';
      setTimeout(() => {
        auditEl.innerHTML = `<span class="badge" style="background:${e.bg}">${e.badge}</span>${e.text}`;
        auditEl.style.opacity = '1';
      }, 130);
    }
    function ledger(now: number) {
      const cyc = (now % CYCLE) / CYCLE;
      if (cyc < lastCyc) fired.clear();
      const cash = CASH * Math.min(1, cyc / 0.06);
      const ease = 1 - Math.pow(1 - Math.min(cyc / 0.7, 1), 3);
      const burn = PROJECTED * ease + Math.sin(now / 220) * 0.05 * ease;
      const margin = cash - burn;
      cashNum.textContent = fmt(cash);
      computeNum.textContent = fmt(burn);
      marginNum.textContent = (margin < 0 ? '- ' : '+ ') + fmt(Math.abs(margin));
      cashBar.style.width = Math.min(100, (cash / CASH) * 100) + '%';
      computeBar.style.width = Math.min(100, (burn / PROJECTED) * 100) + '%';
      marginBar.style.width = Math.min(100, (margin / CASH) * 100) + '%';
      for (let i = 0; i < events.length; i++) {
        if (cyc >= events[i].at && !fired.has(i)) { fired.add(i); showAudit(events[i]); pulse = 1; }
      }
      lastCyc = cyc;
      requestAnimationFrame(ledger);
    }
    requestAnimationFrame(ledger);
  }
  // reduced-motion: HTML already shows the final $200 / $15.32 / +$184.68 values.
</script>
